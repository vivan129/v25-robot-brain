# Never commit real keys. Put your actual key in .env (not committed).
OPENAI_API_KEY=sk-your-key-here

# Optional overrides
OPENAI_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
# If you have a custom voice id, set it here
OPENAI_VOICE_ID=

# Pi camera MJPEG stream (see pi/camera_server.py)
CAMERA_STREAM_URL=http://127.0.0.1:8080/stream.mjpg
LIDAR_STREAM_URL=http://127.0.0.1:8090/scan

# GPIO (BCM numbering)
# Relays default to 17,27,22,23 (physical 11,13,15,16)
RELAY_GPIO=17,27,22,23
# Motor driver L1,L2,R1,R2 default to 13,20,19,21 (physical 33,38,35,40)
MOTOR_GPIO=13,20,19,21
